{
  "editor.rulers": [80],
  "editor.tabSize": 2,

  "cSpell.enableFiletypes": ["gleam"],
  "cSpell.words": [
    "anonymization",
    "bigi",
    "byteorder",
    "charset",
    "charsets",
    "codepoint",
    "codepoints",
    "concat",
    "DICM",
    "DICOM",
    "endianness",
    "dcmfx",
    "gleeunit",
    "ints",
    "println",
    "signedness",
    "simplifile",
    "submatches",
    "uids"
  ],

  "files.exclude": {
    "docs/.vitepress/cache": true,
    "docs/.vitepress/dist": true,
    "docs/node_modules": true,
    "src/gleam/*/build": true,
    "src/rust/target": true
  },

  "debug.allowBreakpointsEverywhere": true
}
